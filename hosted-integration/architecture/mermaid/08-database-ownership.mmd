%% Database / stored-procedure / table ownership
%% Verified against integrations-wfm-database/ contents
flowchart LR
    classDef svc fill:#bfdbfe,stroke:#1e40af,color:#000
    classDef proc fill:#fef9c3,stroke:#854d0e,color:#000
    classDef table fill:#fed7aa,stroke:#9a3412,color:#000
    classDef db fill:#d1fae5,stroke:#065f46,color:#000

    WC[WfmConfig C#]:::svc
    ES[EtlScheduler C#]:::svc
    VP[VerintPublisher Java]:::svc
    IP[IntervalPublisher C#]:::svc

    subgraph Aurora_DB ["Aurora MySQL (integrations-wfm-aurora-db)"]
        direction TB
        T1[TenantStatus_Insert<br/>TenantStatus_Update<br/>TenantStatus_Upsert]:::proc
        T6[Clusters_* + Settings_*<br/>Adherence_* etc.<br/>see StoredProcedures dir]:::proc
        I1[Interval_GetClusters]:::proc
        I2[Interval_GetLastEtlRequest]:::proc
        I3[Interval_UpdateLastEtlRequest]:::proc
        I4[Interval_GetSftpConnectionsByTenantStack]:::proc
        EX[External_GetAllTenantData]:::proc
        TBL_TS[tbl_409_tenant_status<br/>single division_id INT column]:::table
        TBL_IEX[tbl_409_iex_config<br/>iex_* REST/ASCWS columns<br/>sftp_* columns<br/>ascws_* columns]:::table
    end

    subgraph Other_DBs ["Other MySQL DBs"]
        COR[(COR - divisions/BUs)]:::db
        MG[(MyGlobal)]:::db
    end

    subgraph Cluster_DWs ["Per-cluster SQL Server DWs"]
        DW1[IC_GetETLData<br/>DW_SUMMARIZE_AGENT_LOG]:::proc
        DW2[IC_GetETLData<br/>DW_SUMMARIZE_CONTACT_LOG]:::proc
    end

    WC --> T1
    WC --> T6
    WC --> COR
    WC --> MG

    ES --> I1
    ES --> I2
    ES --> I3
    ES --> DW1
    ES --> DW2

    VP --> EX
    IP --> I4

    I4 -.reads.-> TBL_IEX
    EX -.reads.-> TBL_IEX
    T1 -.writes.-> TBL_TS
