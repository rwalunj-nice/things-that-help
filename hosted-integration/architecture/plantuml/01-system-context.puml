@startuml WFM-System-Context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

title NICE WFM Integration Platform - System Context (C4 Level 1)

Person(admin, "Platform Admin", "Configures tenants, clusters, settings via WfmConfig REST API")
Person(sre, "SRE / Oncall", "Monitors metrics, alarms, logs")

System_Boundary(wfm, "NICE WFM Integration Platform") {
    System(platform, "WFM Integration Platform", "11 microservices on AWS ECS Fargate bridging ACD/DFO to WFM backends")
}

System_Ext(acd, "ACD / DFO", "NICE contact center platform: produces orchestration + interval events")
System_Ext(dw, "Cluster Data Warehouses", "Per-cluster SQL Server holding ETL completion timestamps")
System_Ext(verint, "Verint WFM", "Workforce management - REST API target")
System_Ext(iex, "IEX WFM", "ASCWS REST API target for agent state")
System_Ext(ext_wfm, "External WFM Systems", "Per-tenant external WFM endpoints")
System_Ext(aws, "AWS Managed Services", "Kinesis, SQS, DynamoDB, ElastiCache, Aurora, Secrets Manager, CloudWatch")

Rel(acd, platform, "Sends orchestration events", "Kinesis stream")
Rel(dw, platform, "Polled for ETL completion", "SQL Server stored procedures")
Rel(platform, verint, "Publishes queue/agent reports", "HTTPS REST")
Rel(platform, iex, "Publishes agent state", "HTTPS ASCWS REST")
Rel(platform, ext_wfm, "Publishes interval reports", "HTTPS REST")
Rel(platform, aws, "Uses managed services", "AWS SDK")

Rel(admin, platform, "Manages tenant + cluster config", "HTTPS REST")
Rel(sre, platform, "Monitors", "CloudWatch + Prometheus")

SHOW_LEGEND()
@enduml
