# RCA Bot Routine — Environment Variables
#
# Store these as secrets in a custom Routine environment at:
#   claude.ai/settings → Environments → New
#
# Then select that environment when creating each Routine.

# Required for Routine 1 (RCA Forum Reminder) only.
# Get this from your Teams channel: Settings → Connectors → Incoming Webhook → copy URL.
TEAMS_WEBHOOK_URL=https://xxx.webhook.office.com/webhookb2/...

# No ANTHROPIC_API_KEY needed.
# Claude handles AI reasoning natively within the Routine — no separate API key required.
